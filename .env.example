# ═══════════════════════════════════════════════════════════════
# 대라천 (ZOEL LIFE) 환경 변수 템플릿
# 실제 배포 시 .env.local 또는 Vercel 환경변수로 설정
# ═══════════════════════════════════════════════════════════════

# ─── 사이트 기본 ───
NEXT_PUBLIC_SITE_URL=https://www.daracheon.com
NEXT_PUBLIC_SITE_NAME=대라천
CONTACT_EMAIL=contact@daracheon.com

# ─── Google Analytics 4 ───
# 측정 ID (G-XXXXXXXXXX). 미설정 시 GA 스크립트 삽입 안 함.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── 관리자 인증 ───
# 관리자 계정은 /admin/users 에서 DB 에 등록. 환경변수 시드 폴백은 제거됨.
# HMAC 세션 서명 키 — 반드시 32바이트 이상 무작위 문자열
ADMIN_SESSION_SECRET=CHANGE-ME-random-long-string-at-least-32-chars
ADMIN_SESSION_MAX_AGE_DAYS=7

# ─── AI 어시스턴트 (Claude API) ───
# 관리자 로그인 시 노출되는 좌측 AI 패널에서 사용. Anthropic Console에서 발급.
# 미설정 시 패널은 표시되지만 전송 시 500 오류가 반환됨.
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AI 이미지 생성 (Google Imagen via @google/genai) ───
# 관리자 ImageUploadField 의 'AI 생성' 버튼이 사용. Google AI Studio 에서 발급.
# https://aistudio.google.com/apikey
# GOOGLE_GENAI_API_KEY 또는 GEMINI_API_KEY 둘 중 하나만 설정해도 동작.
# GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── 이메일 발송 ───
# 우선순위: SMTP_HOST(있으면) → RESEND_API_KEY → dry-run.
#
# 권장: Gmail / Google Workspace SMTP (도메인 인증 불필요)
# 1) https://myaccount.google.com/security 에서 2단계 인증 활성화
# 2) https://myaccount.google.com/apppasswords 에서 앱 비밀번호 16자 발급
# 3) 아래 변수 설정 (SMTP_PASS 에 공백 제거하고 입력)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# MAIL_FROM=your@gmail.com         # 미설정 시 SMTP_USER 사용
#
# 대안: Resend (도메인 인증 필요)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 이미지 업로드 스토리지 ───
# 아래 두 변수가 모두 설정되면 Cloudinary 사용 (Vercel 배포 시 권장).
# 미설정 시 /public/uploads 에 로컬 저장 (로컬 개발용).
# Cloudinary Dashboard → Settings → Upload → Add upload preset (Unsigned)
NEXT_PUBLIC_CLOUDINARY_CLOUD=ddsu7fl1o
# CLOUDINARY_CLOUD_NAME=ddsu7fl1o
# CLOUDINARY_UPLOAD_PRESET=daracheon_unsigned

# ─── Postgres (향후 JSON DB 마이그레이션 시) ───
# 현재는 JSON 파일 DB 사용 중. 운영 Vercel 배포 시 아래 중 하나 설정 후 scripts/migrate-to-postgres.ts 실행.
# DATABASE_URL=postgresql://user:pass@host:5432/daracheon
# DIRECT_URL=postgresql://user:pass@host:5432/daracheon

# Unsplash API — image search for blog admin (server-only)
# Register at https://unsplash.com/developers → create app → copy Access Key
UNSPLASH_ACCESS_KEY=

# ─── Vercel Blob 데이터 저장 (필수) ───
# BLOB_READ_WRITE_TOKEN: Vercel Blob 읽기/쓰기 토큰.
# BLOB_DATA_PREFIX: 콘텐츠·PII JSON 을 담는 비밀 prefix. 이 값이 PII Blob 을 보호하는
#   유일한 방어선이므로 소스·문서에 평문으로 두지 않는다. 미설정 시 배포 스크립트가 실패.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
# BLOB_DATA_PREFIX=<무작위-비밀-prefix>

# ─── 침향 논문 아카이브 (/thesis) 잠금 (2026-07-07 이후 필수) ───
# 하드코딩 기본값이 제거되어(fail-closed) 이 두 값이 없으면 /thesis 는 열리지 않는다.
# THESIS_PASSWORD: 방문자가 입력할 잠금 해제 비밀번호.
# THESIS_TOKEN: 해제 성공 시 발급되는 쿠키 값(비밀, 무작위 문자열 권장).
# THESIS_PASSWORD=<잠금-해제-비밀번호>
# THESIS_TOKEN=<무작위-쿠키-토큰>
