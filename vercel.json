{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "regions": ["icn1"],
  "headers": [
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/daily-backup", "schedule": "0 15 * * *" },
    { "path": "/api/cron/ga4-daily-report", "schedule": "0 0 * * *" },
    { "path": "/api/cron/inbox-poll", "schedule": "*/5 * * * *" }
  ]
}
